# Database connection string
DATABASE_URI=mongodb://127.0.0.1/verba

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE

ENDPOINT=YOUR_SECRET_HERE
GROQ_API_KEY=YOUR_SECRET_HERE
GROQ_MODEL=YOUR_SECRET_HERE
PEXELS_API_KEY=YOUR_SECRET_HERE
SPEECH_KEY=YOUR_SECRET_HERE
SPEECH_REGION=YOUR_SECRET_HERE
SPEECH_VOICE=YOUR_SECRET_HERE

# Stripe membership
STRIPE_SECRET_KEY=YOUR_SECRET_HERE
STRIPE_WEBHOOK_SECRET=YOUR_SECRET_HERE
STRIPE_PRICE_ID_MEMBERSHIP=price_XXXXXXXXXXXX
# Optional: specific billing portal configuration ID (otherwise Stripe default is used)
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_XXXXXXXXXXXX

# --- Coolify DB / media sync (local scripts) ---
# Remote MongoDB URI from Coolify
COOLIFY_MONGO_URI=mongodb://USER:PASSWORD@HOST:27017/DB_NAME?authSource=admin
# Remote DB name to dump/restore namespace from (recommended)
REMOTE_MONGO_DB=verba
# Local MongoDB restore target (falls back to DATABASE_URI if empty)
LOCAL_MONGO_URI=mongodb://127.0.0.1/verba
# Local DB name (for namespace remap). If different from REMOTE_MONGO_DB,
# restore script remaps REMOTE_MONGO_DB.* -> LOCAL_MONGO_DB.*
LOCAL_MONGO_DB=verba
# Directory where dump archives are stored
DB_BACKUP_DIR=backups/db

# Optional media sync (for upload files under public/media)
COOLIFY_SSH_HOST=user@your-server
COOLIFY_MEDIA_PATH=/home/verba/media
LOCAL_MEDIA_PATH=public/media
# Set to 1 to delete local files missing on remote during media sync
MEDIA_SYNC_DELETE=0
